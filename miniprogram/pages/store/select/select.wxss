.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 24%, var(--surface-muted) 100%);
}

.page-hero {
  margin-bottom: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-kicker {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.hero-chip {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.store-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.store-card {
  padding: 28rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.store-card.active {
  border-color: rgba(229, 77, 66, 0.5);
  box-shadow: var(--shadow-md);
}

.store-main {
  flex: 1;
  min-width: 0;
}

.store-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.store-desc,
.store-address {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.store-tags {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: flex-end;
}

.tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(229, 77, 66, 0.08);
  color: var(--theme-color);
  font-size: 22rpx;
  font-weight: 600;
}

.tag.muted {
  background: rgba(0, 0, 0, 0.06);
  color: var(--text-muted);
}

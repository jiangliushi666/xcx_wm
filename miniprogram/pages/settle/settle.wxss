/* pages/settle/settle.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 28%, var(--surface-muted) 100%);
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.hero {
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
}

.shop-name {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.shop-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.section,
.summary-card {
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-link {
  font-size: 24rpx;
  color: var(--theme-color);
}

.address-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  background: var(--surface-tint);
  border: 2rpx solid rgba(229, 77, 66, 0.14);
  border-radius: 20rpx;
  padding: 24rpx;
}

.address-main {
  flex: 1;
  min-width: 0;
}

.address-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.address-phone {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.address-tag {
  font-size: 20rpx;
  color: var(--theme-color);
  background: rgba(229, 77, 66, 0.12);
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.address-text {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.address-action,
.empty-address-btn {
  min-width: 120rpx;
  padding: 16rpx 20rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--theme-color);
  border: 2rpx solid var(--theme-color);
  box-sizing: border-box;
}

.empty-address {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 4rpx 4rpx;
}

.empty-address-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f1f1f1;
}

.goods-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.goods-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 18rpx;
  background: var(--surface-muted);
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.goods-detail {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goods-price {
  font-size: 26rpx;
  color: var(--theme-color);
  font-weight: 600;
}

.goods-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.goods-subtotal {
  font-size: 30rpx;
  color: var(--theme-color);
  font-weight: 700;
  min-width: 120rpx;
  text-align: right;
}

.remark-input {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 20rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  background: var(--surface-soft);
}

.pay-list {
  display: flex;
  gap: 16rpx;
}

.pay-item {
  flex: 1;
  background: var(--surface-soft);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  padding: 24rpx 20rpx;
}

.pay-item.active {
  background: rgba(229, 77, 66, 0.06);
  border-color: var(--theme-color);
}

.pay-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.pay-desc {
  font-size: 22rpx;
  color: var(--text-muted);
}

.summary-head {
  margin-bottom: 12rpx;
}

.summary-head .section-subtitle {
  display: block;
  margin-top: 8rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
}

.summary-row.total {
  border-top: 1rpx solid #f1f1f1;
  margin-top: 10rpx;
  padding-top: 20rpx;
}

.summary-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.summary-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.summary-value.total {
  color: var(--theme-color);
  font-size: 34rpx;
}

.summary-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.summary-inline-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.summary-inline-value {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  background: rgba(255, 255, 255, 0.98);
  border-radius: var(--radius-xl);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: 0 16rpx 36rpx rgba(0, 0, 0, 0.12);
  backdrop-filter: blur(20rpx);
}

.footer-copy {
  flex: 1;
  min-width: 0;
}

.footer-title {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.footer-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.submit-btn {
  min-width: 220rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  border-radius: 999rpx;
  background: var(--theme-gradient);
  color: white;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: var(--shadow-md);
}

.submit-btn.disabled {
  background: #cfcfcf;
  color: #fff;
  box-shadow: none;
}

/* pages/recharge/recharge.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 24%, var(--surface-muted) 100%);
  padding-bottom: 120rpx;
}

.hero {
  margin: 20rpx;
  padding: 36rpx 30rpx;
}

.hero-label {
  display: block;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.hero-balance {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.balance-symbol {
  color: white;
  font-size: 30rpx;
  font-weight: 700;
}

.balance-num {
  color: white;
  font-size: 56rpx;
  font-weight: 700;
  margin-left: 6rpx;
}

.hero-note {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.recharge-section {
  margin: 0 20rpx 20rpx;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-head .section-subtitle {
  display: block;
  margin-top: 8rpx;
}

.recharge-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.recharge-item {
  width: 48.5%;
  margin-bottom: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.recharge-content {
  flex: 1;
  padding: 28rpx 22rpx 20rpx;
  text-align: center;
}

.recharge-amount {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 12rpx;
}

.amount-symbol {
  font-size: 28rpx;
  color: var(--theme-color);
  font-weight: 700;
}

.amount-num {
  font-size: 56rpx;
  color: var(--theme-color);
  font-weight: 700;
}

.recharge-gift {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--theme-color);
  background: var(--surface-tint);
  margin-bottom: 12rpx;
}

.recharge-gift.hidden {
  visibility: hidden;
}

.recharge-total {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.recharge-btn {
  margin: 0 20rpx 20rpx;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 999rpx;
  background: var(--theme-gradient);
  color: white;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: var(--shadow-md);
}

.empty-state {
  padding: 20rpx 0 28rpx;
}

.tips-section {
  margin: 0 20rpx 120rpx;
  padding: 28rpx;
}

.tips-content {
  margin-top: 18rpx;
}

.tips-item {
  position: relative;
  padding-left: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.9;
}

.tips-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 8rpx;
  height: 8rpx;
  background: var(--theme-color);
  border-radius: 50%;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 22%, var(--surface-muted) 100%);
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.profile-hero {
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 6rpx solid rgba(255, 255, 255, 0.28);
  background: rgba(255, 255, 255, 0.18);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
  line-height: 1.2;
}

.profile-phone {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.profile-phone.muted {
  color: rgba(255, 255, 255, 0.72);
}

.profile-auth {
  display: inline-flex;
  align-items: center;
  margin-top: 18rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.profile-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.profile-stat {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  box-sizing: border-box;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
  margin-bottom: 6rpx;
}

.stat-value {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: white;
}

.quick-section,
.merchant-section {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.quick-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: nowrap;
}

.quick-action {
  flex: 1;
  min-width: 0;
  min-height: 164rpx;
  padding: 20rpx 16rpx;
  border-radius: 20rpx;
  background: var(--surface-soft);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}

.quick-action.primary {
  background: linear-gradient(180deg, rgba(229, 77, 66, 0.08) 0%, rgba(229, 77, 66, 0.04) 100%);
  border-color: rgba(229, 77, 66, 0.12);
}

.quick-icon {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.quick-text {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.merchant-head {
  margin-bottom: 18rpx;
}

.merchant-badge {
  min-width: 110rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.merchant-badge.success {
  color: var(--success-color);
  background: rgba(7, 193, 96, 0.08);
}

.merchant-badge.neutral {
  color: var(--text-secondary);
  background: rgba(0, 0, 0, 0.04);
}

.merchant-summary {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.merchant-summary.empty {
  display: block;
}

.merchant-empty-text {
  font-size: 26rpx;
  color: var(--text-muted);
  line-height: 1.6;
  padding: 4rpx 2rpx 10rpx;
}

.merchant-stat {
  flex: 1;
  width: calc(50% - 8rpx);
  min-height: 136rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(229, 77, 66, 0.04) 0%, var(--surface) 100%);
  border: 1rpx solid rgba(229, 77, 66, 0.1);
  box-sizing: border-box;
}

.merchant-stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--theme-color);
  margin-bottom: 6rpx;
}

.merchant-stat-label {
  font-size: 24rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.merchant-stat-hint {
  font-size: 20rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

.merchant-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.merchant-action {
  flex: 1;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  background: var(--surface-soft);
  color: var(--text-secondary);
}

.merchant-action.primary {
  background: var(--theme-gradient);
  color: white;
}

.version-info {
  padding: 16rpx 0 0;
  text-align: center;
}

.version-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 32rpx;
  box-sizing: border-box;
}

.modal-dialog {
  width: 100%;
  max-width: 600rpx;
  background: var(--surface);
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-title {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-content {
  padding: 20rpx 30rpx 40rpx;
}

.password-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.password-input:last-child {
  margin-bottom: 0;
}

.password-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--theme-color);
  line-height: 1.6;
  text-align: center;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #e5e5e5;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.modal-btn.cancel {
  color: var(--text-muted);
  border-right: 2rpx solid #e5e5e5;
}

.modal-btn.confirm {
  color: var(--theme-color);
  font-weight: 700;
}

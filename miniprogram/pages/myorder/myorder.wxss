.page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 100%);
}

.tabs {
  background: var(--surface);
  display: flex;
  padding: 0 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 2;
}

.tab-item {
  position: relative;
  flex: 1;
  text-align: center;
  padding: 28rpx 0 24rpx;
}

.tab-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.tab-item.active .tab-text {
  color: var(--theme-color);
  font-weight: 700;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: var(--theme-color);
}

.order-list {
  padding: 20rpx 24rpx 36rpx;
}

.order-item {
  background: var(--surface);
  border-radius: var(--radius-xl);
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.order-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx;
  border-bottom: 1rpx solid #f4f4f4;
}

.order-meta {
  flex: 1;
  min-width: 0;
}

.order-type {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.order-id {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  word-break: break-all;
}

.order-status {
  font-size: 26rpx;
  font-weight: 700;
  padding-top: 4rpx;
}

.order-content {
  padding: 28rpx;
}

.recharge-info {
  background: var(--surface-soft);
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
}

.recharge-row,
.summary-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-primary);
  padding: 8rpx 0;
}

.recharge-row.total,
.summary-line.total {
  border-top: 1rpx solid #f1f1f1;
  margin-top: 8rpx;
  padding-top: 16rpx;
  font-weight: 700;
}

.recharge-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.recharge-meta-label,
.recharge-meta-value {
  font-size: 22rpx;
  color: var(--text-muted);
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.goods-image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: var(--surface-muted);
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.goods-detail {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.goods-price {
  font-size: 26rpx;
  color: var(--theme-color);
  font-weight: 600;
}

.goods-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.address-card {
  margin-top: 18rpx;
  background: var(--surface-tint);
  border: 1rpx solid rgba(229, 77, 66, 0.14);
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
}

.address-label {
  display: block;
  font-size: 22rpx;
  color: var(--theme-color);
  margin-bottom: 8rpx;
}

.address-text {
  font-size: 24rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

.order-footer {
  border-top: 1rpx solid #f4f4f4;
  padding: 22rpx 28rpx 26rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 28rpx 28rpx;
}

.order-action {
  min-width: 176rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
}

.order-action.primary {
  background: var(--theme-gradient);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.order-action.ghost {
  border: 1rpx solid rgba(229, 77, 66, 0.16);
  color: var(--theme-color);
  background: var(--surface-tint);
}

.order-time {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.order-summary {
  background: var(--surface-soft);
  border-radius: 20rpx;
  padding: 12rpx 18rpx;
}

.summary-label {
  color: var(--text-secondary);
}

.summary-value {
  color: var(--text-primary);
  font-weight: 600;
}

.summary-value.total {
  color: var(--theme-color);
  font-size: 30rpx;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f2ef 0%, #f5f5f5 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.form-card {
  background: white;
  border-radius: 24rpx;
  padding: 8rpx 28rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f1f1f1;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 14rpx;
}

.form-input,
.picker-input,
.form-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #222;
  background: #fafafa;
  border-radius: 16rpx;
  box-sizing: border-box;
}

.form-input,
.picker-input {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
}

.form-textarea {
  min-height: 160rpx;
  padding: 20rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0 10rpx;
}

.save-btn {
  margin-top: 28rpx;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(229, 77, 66, 0.28);
}

.save-btn.disabled {
  background: #cfcfcf;
  box-shadow: none;
}

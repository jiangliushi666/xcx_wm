.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f2ef 0%, #f5f5f5 100%);
  padding: 24rpx;
}

.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.header-title {
  font-size: 42rpx;
  font-weight: 700;
  color: #222;
}

.header-subtitle {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.header-action {
  min-width: 140rpx;
  padding: 18rpx 22rpx;
  text-align: center;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.address-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.address-item {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid transparent;
}

.address-item.default {
  border-color: rgba(229, 77, 66, 0.25);
  background: #fffaf8;
}

.address-main {
  margin-bottom: 18rpx;
}

.address-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.receiver {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.phone {
  font-size: 26rpx;
  color: #666;
}

.default-tag {
  font-size: 20rpx;
  color: #e54d42;
  background: rgba(229, 77, 66, 0.12);
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
}

.address-text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.action-btn {
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  border: 2rpx solid #e5e5e5;
  color: #555;
}

.action-btn.danger {
  border-color: rgba(229, 77, 66, 0.24);
  color: #e54d42;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 24%, var(--surface-muted) 100%);
}

.page-hero {
  margin-bottom: 20rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-kicker {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  margin-bottom: 10rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.hero-chip {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.search-card {
  margin-bottom: 20rpx;
  padding: 24rpx;
}

.search-bar {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: var(--surface-soft);
  border: 1rpx solid rgba(229, 77, 66, 0.12);
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-actions {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
}

.search-btn,
.clear-btn {
  min-width: 120rpx;
  height: 76rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.search-btn {
  background: var(--theme-gradient);
  color: #fff;
  box-shadow: var(--shadow-sm);
}

.clear-btn {
  background: var(--surface-soft);
  color: var(--text-secondary);
}

.user-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.user-item {
  padding: 22rpx;
}

.user-main {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.user-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.default-avatar {
  width: 100%;
  height: 100%;
  background: var(--surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.user-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.user-badge {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: var(--theme-color);
  background: rgba(229, 77, 66, 0.08);
}

.user-detail {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.audit-card {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  background: var(--surface-soft);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.audit-line {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.user-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.action-btn {
  flex: 1;
  min-height: 70rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.balance-btn {
  color: var(--theme-color);
  background: rgba(229, 77, 66, 0.08);
}

.miandan-btn {
  color: #fff;
  background: var(--theme-gradient);
}

.list-footer {
  padding: 6rpx 0 0;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
}

.empty-state {
  padding: 90rpx 32rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  z-index: 9999;
}

.modal-dialog {
  width: 100%;
  max-width: 640rpx;
  background: var(--surface);
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.modal-title {
  padding: 36rpx 32rpx 0;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-content {
  padding: 22rpx 32rpx 36rpx;
}

.user-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 26rpx;
  padding-bottom: 26rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.preview-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 18rpx;
}

.preview-avatar image {
  width: 100%;
  height: 100%;
}

.preview-name {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.preview-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.preview-audit {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.6;
  text-align: center;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(229, 77, 66, 0.12);
  background: var(--surface-soft);
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 148rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(229, 77, 66, 0.12);
  background: var(--surface-soft);
  font-size: 28rpx;
  color: var(--text-primary);
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  color: var(--text-muted);
  border-right: 1rpx solid rgba(0, 0, 0, 0.06);
}

.modal-btn.confirm {
  color: var(--theme-color);
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 24%, var(--surface-muted) 100%);
}

.page-hero {
  margin-bottom: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-kicker {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.hero-chip {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.store-tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.store-tab {
  display: inline-flex;
  flex-direction: column;
  justify-content: center;
  min-width: 220rpx;
  margin-right: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid transparent;
  box-shadow: var(--shadow-sm);
  box-sizing: border-box;
}

.store-tab.active {
  border-color: rgba(229, 77, 66, 0.45);
  background: #fff;
}

.store-tab-name {
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.store-tab-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.form-section {
  margin-bottom: 20rpx;
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(229, 77, 66, 0.12);
  background: var(--surface-soft);
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(229, 77, 66, 0.12);
  background: var(--surface-soft);
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.switch-item .form-label {
  margin-bottom: 0;
}

.save-footer {
  margin-top: 8rpx;
  display: flex;
  gap: 18rpx;
}

.save-btn {
  flex: 1;
  background: var(--theme-gradient);
  color: #fff;
  padding: 28rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: var(--shadow-md);
}

.delete-btn {
  width: 220rpx;
  background: rgba(0, 0, 0, 0.06);
  color: var(--text-muted);
  padding: 28rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

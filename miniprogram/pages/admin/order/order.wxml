<view class="page">
  <view class="page-shell">
    <view class="hero-panel page-hero">
      <view class="page-label">ADMIN ORDER</view>
      <view class="page-title">订单管理</view>
      <view class="page-copy">查看充值和外卖订单，推进履约状态，并记录操作备注。</view>
      <view class="hero-actions">
        <view class="action-btn hero-ghost" bindtap="refreshOrders">刷新列表</view>
      </view>
    </view>

    <view class="surface-card page-section">
      <view class="section-header">
        <view>
          <view class="section-title">订单筛选</view>
          <view class="section-subtitle">支持全部订单、充值订单和外卖订单切换。</view>
        </view>
        <view class="section-count">{{orders.length}} 条</view>
      </view>
      <van-tabs active="{{orderType}}" bind:change="onChange" color="#e54d42" swipeable="{{false}}">
        <van-tab title="全部订单" />
        <van-tab title="充值订单" />
        <van-tab title="外卖订单" />
      </van-tabs>
    </view>

    <view class="surface-card page-section list-section">
      <view class="order-list">
        <view class="surface-card order-card" wx:for="{{orders}}" wx:key="_id">
          <view class="order-card-head">
            <view class="order-user">
              <image class="user-avatar" src="{{item.userAvatar || '/images/tabBar/me.png'}}" mode="aspectFill"></image>
              <view class="user-stack">
                <view class="user-name">{{item.userNickName || item.receiverName || '匿名用户'}}</view>
                <view class="user-phone" wx:if="{{item.userPhone || item.receiverMobile}}">
                  {{item.userPhone || item.receiverMobile}}
                </view>
                <view class="user-phone muted" wx:else>未留联系方式</view>
              </view>
            </view>
            <view class="head-actions">
              <view class="status-pill {{item.typeTone}}">{{item.typeText}}</view>
              <view class="status-pill {{item.statusTone}}">{{item.statusText}}</view>
            </view>
          </view>

          <view class="order-body">
            <view class="metric-grid" wx:if="{{item.type === 'recharge'}}">
              <view class="metric-card highlight">
                <text class="metric-label">订单状态</text>
                <view class="metric-value">{{item.statusText}}</view>
              </view>
              <view class="metric-card">
                <text class="metric-label">充值金额</text>
                <view class="metric-value">¥{{item.amount}}</view>
              </view>
              <view class="metric-card">
                <text class="metric-label">赠送金额</text>
                <view class="metric-value">¥{{item.giveAmount}}</view>
              </view>
              <view class="metric-card">
                <text class="metric-label">到账金额</text>
                <view class="metric-value">¥{{item.totalGet}}</view>
              </view>
            </view>

            <view class="metric-grid" wx:elif="{{item.type === 'order'}}">
              <view class="metric-card highlight">
                <text class="metric-label">订单状态</text>
                <view class="metric-value">{{item.statusText}}</view>
              </view>
              <view class="metric-card">
                <text class="metric-label">下单时间</text>
                <view class="metric-value">{{item.createTimeText}}</view>
              </view>
              <view class="metric-card">
                <text class="metric-label">配送费</text>
                <view class="metric-value">¥{{item.deliveryFeeText}}</view>
              </view>
              <view class="metric-card">
                <text class="metric-label">实付金额</text>
                <view class="metric-value">¥{{item.payAmountText}}</view>
              </view>
            </view>

            <view class="goods-list" wx:if="{{item.type === 'order' && item.goods && item.goods.length > 0}}">
              <view class="goods-item" wx:for="{{item.goods}}" wx:for-item="goods" wx:key="goodsId">
                <image class="goods-image" src="{{goods.dishImage}}" mode="aspectFill"></image>
                <view class="goods-info">
                  <view class="goods-name">{{goods.dishName}}</view>
                  <view class="goods-tags" wx:if="{{goods.tags && goods.tags.length > 0}}">
                    <view class="goods-tag" wx:for="{{goods.tags}}" wx:key="index" wx:for-item="tagVal">{{tagVal}}</view>
                  </view>
                  <view class="goods-detail">
                    <text class="goods-price">¥{{goods.price}}</text>
                    <text class="goods-count">×{{goods.count}}</text>
                  </view>
                </view>
              </view>
            </view>

            <view class="address-panel" wx:if="{{item.type === 'order' && item.addressText}}">
              <text class="panel-label">配送地址</text>
              <view class="panel-text">{{item.addressText}}</view>
            </view>

            <view class="note-panel" wx:if="{{item.cancelReasonText || item.operatorRemarkText}}">
              <view class="meta-row" wx:if="{{item.cancelReasonText}}">
                <text class="meta-label">取消原因</text>
                <text class="meta-value">{{item.cancelReasonText}}</text>
              </view>
              <view class="meta-row" wx:if="{{item.operatorRemarkText}}">
                <text class="meta-label">操作备注</text>
                <text class="meta-value">{{item.operatorRemarkText}}</text>
              </view>
            </view>
          </view>

          <view class="order-footer">
            <view class="footer-meta">
              <view class="meta-row">
                <text class="meta-label">下单时间</text>
                <text class="meta-value">{{item.createTimeText}}</text>
              </view>
              <view class="meta-row">
                <text class="meta-label">打印状态</text>
                <text class="status-pill {{item.printStatusTone}}">{{item.printStatusText}}</text>
              </view>
              <view class="meta-row">
                <text class="meta-label">订单编号</text>
                <text class="meta-value">{{item._id}}</text>
              </view>
            </view>

            <view class="footer-actions" wx:if="{{item.nextStatus || item.canCancel}}">
              <view class="action-row">
                <view
                  class="action-btn secondary compact"
                  wx:if="{{item.canCancel}}"
                  catchtap="openActionDialog"
                  data-id="{{item._id}}"
                  data-status="已取消">
                  取消订单
                </view>
                <view
                  class="action-btn primary compact"
                  wx:if="{{item.nextStatus}}"
                  catchtap="openActionDialog"
                  data-id="{{item._id}}"
                  data-status="{{item.nextStatus}}">
                  {{item.nextStatusText}}
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="list-footer" wx:if="{{orders.length === 0}}">
          暂无订单数据
        </view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{actionDialogVisible}}" bindtap="closeActionDialog">
    <view class="action-dialog" catchtap="stopPropagation">
      <view class="dialog-title">{{actionDialogTitle}}</view>
      <view class="dialog-subtitle">{{actionDialogSubtitle}}</view>
      <textarea
        wx:if="{{actionDialogRequiresCancelReason}}"
        class="dialog-textarea"
        value="{{actionDialogCancelReason}}"
        placeholder="输入取消原因"
        maxlength="100"
        bindinput="onCancelReasonInput"
      />
      <textarea
        class="dialog-textarea secondary"
        value="{{actionDialogOperatorRemark}}"
        placeholder="输入操作备注（可选）"
        maxlength="100"
        bindinput="onOperatorRemarkInput"
      />
      <view class="dialog-actions">
        <view class="action-btn secondary wide" bindtap="closeActionDialog">返回</view>
        <view class="action-btn primary wide" bindtap="submitActionDialog">
          {{actionDialogSubmitting ? '提交中...' : '确认'}}
        </view>
      </view>
    </view>
  </view>
</view>

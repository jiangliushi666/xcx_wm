.page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 24%, var(--surface-muted) 100%);
}

.page-shell {
  padding: 24rpx 30rpx 48rpx;
}

.page-hero {
  padding: 32rpx;
  border-radius: 28rpx;
  box-shadow: var(--shadow-md);
}

.page-label {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.7);
}

.page-title {
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.page-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.84);
}

.hero-actions {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-note {
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.78);
}

.page-section {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.section-count {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(229, 77, 66, 0.08);
  color: var(--theme-color);
  font-size: 22rpx;
  font-weight: 600;
}

.helper-banner {
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(229, 77, 66, 0.06);
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.6;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notice-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: var(--surface-soft);
}

.notice-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-actions,
.modal-footer {
  display: flex;
  gap: 12rpx;
}

.notice-content {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-primary);
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.status-pill.success {
  color: var(--success-color);
  background: rgba(7, 193, 96, 0.12);
}

.status-pill.neutral {
  color: var(--text-secondary);
  background: rgba(0, 0, 0, 0.06);
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.action-btn.compact {
  min-height: 64rpx;
  padding: 0 22rpx;
}

.action-btn.wide {
  flex: 1;
}

.action-btn.primary {
  background: var(--theme-gradient);
  color: #fff;
  box-shadow: var(--shadow-md);
}

.action-btn.secondary {
  background: rgba(229, 77, 66, 0.08);
  color: var(--theme-color);
}

.action-btn.danger {
  background: rgba(245, 108, 108, 0.12);
  color: var(--danger-color);
}

.action-btn.hero-ghost {
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.44);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  z-index: 30;
}

.modal-dialog {
  width: 100%;
  background: var(--surface);
  border-radius: 28rpx;
  overflow: hidden;
}

.modal-head {
  padding: 32rpx 32rpx 12rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.modal-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-muted);
}

.modal-content {
  padding: 12rpx 32rpx 32rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  background: var(--surface-soft);
  border: 1rpx solid rgba(229, 77, 66, 0.12);
  border-radius: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-primary);
}

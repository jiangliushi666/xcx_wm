/* pages/admin/admin.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, var(--surface-tint) 0%, var(--surface-muted) 22%, var(--surface-muted) 100%);
  padding-bottom: 40rpx;
}

/* 经营看板头部 */
.hero-card {
  margin: 24rpx 30rpx 0;
  padding: 32rpx;
  border-radius: 28rpx;
  background: var(--theme-gradient-strong);
  color: white;
  box-shadow: var(--shadow-md);
}

.hero-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.hero-title-block {
  flex: 1;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.5;
}

.hero-badge {
  min-width: 128rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.hero-badge.active {
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.hero-badge.muted {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx dashed rgba(255, 255, 255, 0.28);
}

.hero-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.5;
}

.hero-notice {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.96);
  font-size: 24rpx;
  line-height: 1.6;
}

.hero-sync {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
}

.hero-actions {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}

.hero-action-btn {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

/* 共用区块标题 */
.section-title {
  padding: 0 30rpx 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

/* 今日看板 */
.stats-section {
  margin: 24rpx 30rpx 0;
  padding: 26rpx 0 12rpx;
  background: var(--surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.stats-grid {
  padding: 0 20rpx 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-card {
  width: calc(50% - 8rpx);
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(229, 77, 66, 0.04) 0%, var(--surface) 100%);
  border: 1rpx solid rgba(229, 77, 66, 0.12);
  box-sizing: border-box;
}

.stat-label {
  font-size: 24rpx;
  color: #8b5c54;
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--theme-color);
  margin-bottom: 8rpx;
}

.stat-hint {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

.stats-empty {
  padding: 0 30rpx 16rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.6;
}

.refresh-link {
  margin-top: 10rpx;
  color: var(--theme-color);
  font-weight: 600;
}

/* 最近订单 */
.recent-section {
  margin: 24rpx 30rpx 0;
  padding-top: 24rpx;
  background: var(--surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.recent-list {
  padding: 0 20rpx 16rpx;
}

.recent-item {
  padding: 20rpx;
  border-radius: 18rpx;
  background: var(--surface-soft);
  margin-bottom: 16rpx;
}

.recent-item:last-child {
  margin-bottom: 0;
}

.recent-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.recent-no {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.recent-meta {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.4;
}

.recent-status {
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.recent-detail {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.recent-address {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.recent-address-name {
  display: block;
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: 4rpx;
}

.recent-address-text {
  display: block;
}

.recent-price {
  font-size: 32rpx;
  color: var(--theme-color);
  font-weight: 700;
  flex-shrink: 0;
}

/* 菜单区域 */
.menu-section {
  margin: 30rpx;
  background: var(--surface);
  border-radius: 20rpx;
  overflow: hidden;
  padding: 30rpx 0;
  box-shadow: var(--shadow-sm);
}

.menu-grid {
  padding: 0 10rpx;
}

/* 菜单项图标大小 */
.menu-grid .van-grid-item__icon {
  font-size: 56rpx !important;
  height: 56rpx !important;
}

/* 菜单项文字大小 */
.menu-grid .van-grid-item__text {
  font-size: 32rpx !important;
  font-weight: 500;
  margin-top: 15rpx;
  color: var(--text-primary);
}

/* 返回按钮 */
.back-btn {
  margin: 30rpx;
  padding: 30rpx;
  background: var(--surface);
  border-radius: 20rpx;
  text-align: center;
  font-size: 32rpx;
  color: var(--text-secondary);
  box-shadow: var(--shadow-sm);
}

/* 密码输入弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-dialog {
  width: 600rpx;
  background: var(--surface);
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-title {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.modal-content {
  padding: 20rpx 30rpx 40rpx;
}

.password-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.password-input:last-child {
  margin-bottom: 0;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #e5e5e5;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.modal-btn.cancel {
  color: var(--text-muted);
  border-right: 2rpx solid #e5e5e5;
}

.modal-btn.confirm {
  color: var(--theme-color);
  font-weight: bold;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f2ef 0%, #f5f5f5 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  color: white;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 16rpx 36rpx rgba(229, 77, 66, 0.22);
}

.order-no {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.order-status {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.order-time {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.section {
  background: white;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 18rpx;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  min-width: 180rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
}

.action-btn.primary {
  background: #e54d42;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(229, 77, 66, 0.18);
}

.action-btn.ghost {
  border: 1rpx solid #ffd0cc;
  color: #e54d42;
  background: #fff8f7;
}

.address-card {
  background: #fff7f6;
  border: 2rpx solid #ffd9d6;
  border-radius: 20rpx;
  padding: 24rpx;
}

.receiver {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 10rpx;
}

.phone {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.address-text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.6;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #f1f1f1;
}

.goods-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 18rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 10rpx;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.goods-meta {
  font-size: 24rpx;
  color: #888;
}

.goods-subtotal {
  font-size: 28rpx;
  color: #e54d42;
  font-weight: 700;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #444;
}

.summary-row.total {
  border-top: 1rpx solid #f1f1f1;
  margin-top: 10rpx;
  padding-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}

.remark {
  font-size: 26rpx;
  color: #444;
  line-height: 1.7;
  background: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx;
}

.status-line {
  font-size: 26rpx;
  color: #444;
  line-height: 1.8;
}

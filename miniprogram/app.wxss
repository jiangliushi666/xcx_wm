/**app.wxss**/
@import './components/colorui/animation.wxss';
@import './components/colorui/icon.wxss';
@import './components/colorui/main.wxss';

/* 全局红色主题样式 */
page {
  --theme-color: #e54d42;
  --theme-color-strong: #b71c1c;
  --theme-color-soft: #f37370;
  --theme-gradient: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  --theme-gradient-strong: linear-gradient(135deg, #b71c1c 0%, #ef5350 100%);
  --accent-color: #667eea;
  --accent-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  --success-color: #07c160;
  --warning-color: #ff9800;
  --danger-color: #f56c6c;
  --text-primary: #222;
  --text-secondary: #666;
  --text-muted: #999;
  --surface: #ffffff;
  --surface-soft: #fafafa;
  --surface-muted: #f5f5f5;
  --surface-tint: #fff7f4;
  --shadow-sm: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 10rpx 30rpx rgba(229, 77, 66, 0.14);
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;
  background-color: #f5f5f5;
}

.container {
  padding: 20rpx;
}

/* 主题按钮 */
.btn-theme {
  background: var(--theme-gradient);
  color: white;
  border: none;
  border-radius: 999rpx;
  padding: 20rpx 40rpx;
}

.btn-theme-plain {
  background: white;
  color: var(--theme-color);
  border: 2rpx solid var(--theme-color);
  border-radius: 999rpx;
  padding: 20rpx 40rpx;
}

/* 卡片样式 */
.card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
}

/* 标签 */
.tag-red {
  background: var(--theme-color);
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

/* 价格样式 */
.price {
  color: var(--theme-color);
  font-weight: bold;
}

.price-symbol {
  font-size: 24rpx;
}

.price-num {
  font-size: 36rpx;
}

/* 徽章 */
.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: var(--theme-color);
  color: white;
  border-radius: 50%;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 20rpx;
  padding: 0 8rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 20rpx 0;
}

.surface-card {
  background: var(--surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.surface-card.tight {
  border-radius: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
}

.chip.brand {
  color: var(--theme-color);
  background: rgba(229, 77, 66, 0.08);
}

.chip.neutral {
  color: var(--text-secondary);
  background: rgba(0, 0, 0, 0.04);
}

.chip.success {
  color: var(--success-color);
  background: rgba(7, 193, 96, 0.08);
}

.hero-panel {
  background: var(--theme-gradient);
  border-radius: var(--radius-xl);
  color: white;
  box-shadow: var(--shadow-md);
}

